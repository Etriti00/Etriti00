{
  "name": "playwright-react-ts-starter",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Opinionated React 18 + TypeScript starter with Vitest + Playwright (3 browsers) and sharded GitHub Actions CI.",
  "author": "Etrit Neziri <etritneziri@hotmail.com> (https://github.com/Etriti00)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Etriti00/playwright-react-ts-starter.git"
  },
  "homepage": "https://github.com/Etriti00/playwright-react-ts-starter#readme",
  "bugs": {
    "url": "https://github.com/Etriti00/playwright-react-ts-starter/issues"
  },
  "keywords": ["react", "typescript", "playwright", "vitest", "testing", "ci", "starter"],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "happy-dom": "^15.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
